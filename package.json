{
  "name": "lucida-slides",
  "version": "0.1.3",
  "description": "YAML-native slide deck builder — content + theme → standalone HTML or 16:9 PDF",
  "type": "module",
  "bin": {
    "lucida": "dist-cli/lucida.js"
  },
  "files": [
    "dist-cli/",
    "engine/",
    "themes/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "slides",
    "presentation",
    "deck",
    "yaml",
    "html",
    "pdf",
    "slide-deck",
    "board-deck"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pengelbrecht/lucida.git"
  },
  "license": "MIT",
  "author": "Peter Engelbrecht",
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "optionalDependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
